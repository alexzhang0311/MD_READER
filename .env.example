# ── Production environment variables ──
# Copy this file to .env and modify the values

# REQUIRED: Change this to a strong random secret
MD_READER_SECRET=change-me-to-a-random-string-at-least-32-chars

# Path to your markdown files directory
MD_READER_DIR=/data/markdown

# Server port
MD_READER_PORT=5000

# MUST be false in production
MD_READER_DEBUG=false
